# Mandi-Max — Configuration Template
# Copy this to .env and fill in your real keys. NEVER commit .env to git.

# --- Sarvam AI (get from dashboard.sarvam.ai) ---
SARVAM_API_KEY=your_sarvam_api_key_here

# --- Geocoding (OpenCage — 2500 free calls/day, opencagedata.com) ---
OPENCAGE_API_KEY=your_opencage_api_key_here

# --- Databricks ---
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_pat_token_here
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
DATABRICKS_CATALOG=workspace

# --- React Frontend ---
REACT_APP_API_BASE_URL=https://your-databricks-app-url.aws.databricksapps.com

# --- WhatsApp (Twilio) ---
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
